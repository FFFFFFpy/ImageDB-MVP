{
  "name": "imagedb-mvp",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "scripts": {
    "dev": "pnpm --filter @imagedb/desktop dev",
    "build": "pnpm --filter @imagedb/desktop build",
    "typecheck": "pnpm --filter @imagedb/desktop typecheck",
    "test:unit": "pnpm --filter @imagedb/desktop test:unit",
    "format": "prettier --write . && cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "format:check": "prettier --check . && cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml -- --check",
    "rust:clippy": "cargo clippy --manifest-path apps/desktop/src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "rust:test": "cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "rust:test:real": "node scripts/run-real-rust-tests.mjs",
    "check": "pnpm typecheck && pnpm test:unit && pnpm format:check && pnpm rust:clippy && pnpm rust:test",
    "release:gate": "node scripts/run-m9-release-gate.mjs",
    "release:runtime": "node scripts/package-postgres-runtime.mjs",
    "release:verify-artifacts": "node scripts/verify-release-artifacts.mjs",
    "release:install-gate": "node scripts/run-m9-installation-gate.mjs",
    "release:performance": "node scripts/run-m9-performance-gate.mjs",
    "release:dataset": "node scripts/verify-m9-acceptance-dataset.mjs"
  },
  "devDependencies": {
    "prettier": "^3.0.0"
  }
}
